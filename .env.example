# Cadence — environment variables. Copy to `.env` and fill in real values.
# `.env` is gitignored; never commit real secrets.

# Shared secret required by POST /api/webhooks/restock-task in the
# `x-webhook-secret` header. Use a long random value (e.g. `openssl rand -hex 32`).
# While this is unset the webhook fails closed with HTTP 503 instead of running open.
CADENCE_WEBHOOK_SECRET=

# Path to the SQLite task store. Defaults to ./cadence.db when unset.
# On an ephemeral host (e.g. Render's free tier) the file does not survive a
# restart; point this at a persistent volume for durable task storage.
CADENCE_DB_PATH=cadence.db
